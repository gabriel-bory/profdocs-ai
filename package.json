{
  "name": "profdocs-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Full-stack AI document intelligence platform built with Angular, NestJS, PostgreSQL, pgvector, Docker and RAG.",
  "license": "MIT",
  "author": "Gabriel Bory Prevez",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "prepare": "husky",
    "commitlint": "commitlint --from HEAD~1 --to HEAD --verbose",
    "dev:web": "pnpm --filter web start",
    "dev:api": "pnpm --filter api start:dev",
    "dev:docs": "pnpm --filter docs dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter web build",
    "build:api": "pnpm --filter api build",
    "build:docs": "pnpm --filter docs build",
    "e2e": "playwright test -c apps/web/e2e/playwright.config.ts",
    "e2e:ui": "playwright test -c apps/web/e2e/playwright.config.ts --ui",
    "e2e:headed": "playwright test -c apps/web/e2e/playwright.config.ts --headed",
    "e2e:manual": "playwright test -c apps/web/e2e/playwright.config.ts --grep @manual",
    "e2e:report": "playwright show-report apps/web/e2e/playwright-report"
  },
  "keywords": [
    "angular",
    "nestjs",
    "typescript",
    "postgresql",
    "pgvector",
    "rag",
    "ai",
    "docker",
    "monorepo",
    "portfolio"
  ],
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.61.0",
    "husky": "^9.1.7"
  }
}
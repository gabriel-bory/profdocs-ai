{
  "name": "@profdocs-ai/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared TypeScript contracts for ProfDocs AI.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./context-engine": {
      "types": "./dist/context-engine/index.d.ts",
      "default": "./dist/context-engine/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm build && node --test tests/*.test.mjs"
  },
  "devDependencies": {
    "typescript": "~5.9.2"
  }
}
